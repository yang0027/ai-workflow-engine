    label?: string;
    inputs?: {
      text?: string;
      model?: string;
      mode?: string;
      [key: string]: any;
    };
    outputs?: {
      text?: string;
      output?: string;
    };
  };
  selected?: boolean;
  style?: React.CSSProperties;
}

